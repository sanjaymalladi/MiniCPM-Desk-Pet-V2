# Heavy / generated artifacts
node_modules/
.venv/
__pycache__/
*.pyc
*.pyo
.DS_Store
*.log

# Build / dist outputs
dist/
# Legacy build dir — keep the spec + script committed alongside the
# DEPRECATED marker.
build/*
!build/sidecar.spec
!build/build-sidecar.sh
!build/DEPRECATED.md

# New sidecar build artifacts. Spec / scripts under minicpm-sidecar/
# stay committed via that directory's own .gitignore.
minicpm-sidecar/bin/
minicpm-sidecar/build/build/
minicpm-sidecar/build/dist/
minicpm-sidecar/third_party/llama.cpp/

# Model weights — too big to ship, friends/colleagues download separately
models/

# Editor / OS junk
.vscode/
.idea/
*.swp
*~

# Local scratch dir for one-off assets/exports
temp/

# Local env / secrets
.env
.env.local

# Bridge runtime files
*.pid
runtime-port.json

# uv lock — keep
# (don't ignore uv.lock; it's needed for reproducible installs)
