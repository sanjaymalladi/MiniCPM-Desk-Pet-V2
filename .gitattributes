# LoRA adapter PEFT sources (.safetensors) live in Git LFS (~20MB each,
# would otherwise bloat the pack and slow down clones).
#
# The converted .gguf artefacts we ship to the Electron app are NOT in
# git anymore — they are fetched from Hugging Face at build time by
# clawd-on-desk/scripts/fetch-adapters.js (see .gitignore). This avoids
# GitHub LFS bandwidth quotas and the "shipped a 130-byte LFS pointer
# stub" failure mode (gguf magic 'vers' instead of 'GGUF').
adapters/**/*.safetensors filter=lfs diff=lfs merge=lfs -text

# Legacy adapters that predate the LFS switch keep their in-tree blobs
# so we don't have to rewrite already-pushed history. Add new exceptions
# here as needed; they MUST come AFTER the catch-all rule above.
adapters/lora_chuuni_20260519_1449/adapter_model.safetensors -filter -diff -merge -text
